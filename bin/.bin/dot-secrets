#!/usr/bin/env bash
#
# dot-secrets — materialize per-host secrets from Vaultwarden into $HOME.
#
# Reads a manifest mapping Bitwarden/Vaultwarden items to local destinations and
# writes each one as a real file (0600) outside any Stow package, so `git pull`
# and `stow` can never touch it and it can never be committed.
#
#   dot-secrets [sync] [--dry-run] [--server URL]
#
#   sync          fetch every manifest row (default command)
#   --dry-run     parse + print planned actions; no vault calls, no writes
#   --server URL  point the bw CLI at this Vaultwarden (else $BW_SERVER / existing config)
#
# Auth: needs the personal `bw` CLI logged in (`bw login --apikey`, env
# BW_CLIENTID/BW_CLIENTSECRET). Unlock is the one unavoidable prompt unless
# $BW_PASSWORD is set. Rows whose item is absent from the vault are skipped, so a
# host without (say) mutt access just skips the fastmail rows. Idempotent.

set -euo pipefail
umask 077

# Cross-platform helpers (has). Prefer the dotfiles platform library.
if ! type has >/dev/null 2>&1; then
	if [ -r "${XDG_CONFIG_HOME:-$HOME/.config}/shell/lib/platform.sh" ]; then
		# shellcheck disable=SC1091  # sourced at runtime from the XDG config path
		. "${XDG_CONFIG_HOME:-$HOME/.config}/shell/lib/platform.sh"
	else
		has() { command -v "$1" >/dev/null 2>&1; }
	fi
fi

MANIFEST="${DOT_SECRETS_MANIFEST:-${XDG_CONFIG_HOME:-$HOME/.config}/dot-secrets/manifest.tsv}"

dry_run=0
server="${BW_SERVER:-}"
while [ $# -gt 0 ]; do
	case "$1" in
		sync)         : ;;   # the only command; accepted for explicitness
		--dry-run|-n) dry_run=1 ;;
		--server)     shift; server="${1:-}" ;;
		-h|--help)    sed -n '3,21p' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
		*) printf 'dot-secrets: unknown argument: %s\n' "$1" >&2; exit 2 ;;
	esac
	shift
done

die()  { printf 'dot-secrets: %s\n' "$*" >&2; exit 1; }
log()  { printf 'dot-secrets: %s\n' "$*" >&2; }

[ -r "$MANIFEST" ] || die "manifest not found: $MANIFEST"

# Expand a leading ~/ to $HOME (the only tilde form the manifest uses).
expand() { if [ "${1#\~/}" != "$1" ]; then printf '%s' "$HOME/${1#\~/}"; else printf '%s' "$1"; fi; }

# --- dry run: parse + report, no vault, no writes ---------------------------
if [ "$dry_run" = 1 ]; then
	n=0
	while read -r kind item source dest mode <&3 || [ -n "${kind:-}" ]; do
		case "${kind:-}" in ''|'#'*) continue ;; esac
		n=$((n + 1))
		printf 'would fetch  %-6s %-14s %-11s -> %s (%s)\n' \
			"$kind" "$item" "$source" "$(expand "$dest")" "$mode"
	done 3< "$MANIFEST"
	log "dry-run: $n row(s); no vault calls, nothing written"
	exit 0
fi

# --- real sync: need bw + jq ------------------------------------------------
has bw || die "bw CLI not found. Install it (brew install bitwarden-cli / npm i -g @bitwarden/cli) then 'bw login --apikey'."
has jq || die "jq not found. Install it (brew install jq / apt install jq)."

[ -n "$server" ] && bw config server "$server" >/dev/null

status="$(bw status | jq -r '.status' 2>/dev/null || echo unknown)"
[ "$status" = unauthenticated ] && die "bw is not logged in. Run 'bw login --apikey' (env BW_CLIENTID/BW_CLIENTSECRET) first."

# Unlock unless a session was handed to us via the environment.
locked_by_us=0
if [ -z "${BW_SESSION:-}" ]; then
	if [ -n "${BW_PASSWORD:-}" ]; then
		BW_SESSION="$(bw unlock --passwordenv BW_PASSWORD --raw)"
	else
		BW_SESSION="$(bw unlock --raw)"   # the one unavoidable interactive prompt
	fi
	[ -n "$BW_SESSION" ] || die "unlock failed"
	export BW_SESSION
	locked_by_us=1
fi

bw sync >/dev/null

written=0 skipped=0
while read -r kind item source dest mode <&3 || [ -n "${kind:-}" ]; do
	case "${kind:-}" in ''|'#'*) continue ;; esac
	dest="$(expand "$dest")"

	# One lookup per row; absent item -> skip (host simply lacks this secret).
	if ! item_json="$(bw get item "$item" 2>/dev/null)"; then
		log "skip: $item (not in vault)"
		skipped=$((skipped + 1))
		continue
	fi

	mkdir -p "$(dirname "$dest")"
	tmp="$dest.tmp.$$"

	case "$kind" in
		field)
			val="$(printf '%s' "$item_json" | jq -r --arg n "$source" '
				(if $n == "password" then .login.password
				 else (.fields[]? | select(.name == $n) | .value) end) // empty')"
			[ -n "$val" ] || { log "skip: $item/$source (field empty)"; skipped=$((skipped + 1)); rm -f "$tmp"; continue; }
			printf '%s\n' "$val" > "$tmp"
			;;
		note)
			val="$(printf '%s' "$item_json" | jq -r '.notes // empty')"
			[ -n "$val" ] || { log "skip: $item note (empty)"; skipped=$((skipped + 1)); rm -f "$tmp"; continue; }
			printf '%s\n' "$val" > "$tmp"
			;;
		attach)
			id="$(printf '%s' "$item_json" | jq -r '.id')"
			if ! bw get attachment "$source" --itemid "$id" --output "$tmp" --raw >/dev/null 2>&1; then
				log "skip: $item attachment $source (not found)"
				skipped=$((skipped + 1)); rm -f "$tmp"; continue
			fi
			;;
		*)
			log "skip: unknown kind '$kind' for $item"
			skipped=$((skipped + 1)); rm -f "$tmp"; continue
			;;
	esac

	chmod "$mode" "$tmp"
	mv -f "$tmp" "$dest"
	log "wrote $dest ($mode)"
	written=$((written + 1))
done 3< "$MANIFEST"

[ "$locked_by_us" = 1 ] && bw lock >/dev/null 2>&1 || true

log "done: $written written, $skipped skipped"
