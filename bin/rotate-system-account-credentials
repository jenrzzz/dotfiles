#!/bin/bash
set -e
set -o pipefail

randomchars() {
  ruby -r 'securerandom' -e 'puts SecureRandom.alphanumeric(10)'
}

generate_password() {
  echo "$(randomchars)-$(randomchars)"
}

user="$1"
current_password="$(vault read -field password "hwwt/system-accounts/${user}")"
new_password="$(generate_password)"

echo "User:             ${user}"
echo "Current password: ${current_password}"
echo "New password:     ${new_password}"
