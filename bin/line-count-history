#!/bin/bash

# Check if the filename is provided
if [ -z "$1" ]; then
  echo "Usage: $0 <filename>"
  exit 1
fi

# Remember the current branch to go back to it later
CURRENT_BRANCH=$(git symbolic-ref --short HEAD)

# Detach HEAD so we can navigate commits without affecting branches
git checkout --detach

# Iterate through all the commit hashes for the given file
for COMMIT_HASH in $(git log --pretty=format:'%H' -- "$1"); do
  # Check out the file at the commit
  git checkout $COMMIT_HASH -- "$1" 2>/dev/null
  
  # Count the lines and print along with the commit hash
  NUM_LINES=$(wc -l < "$1")
  echo "$COMMIT_HASH: $NUM_LINES lines"
done | tac

echo
# Return to the original state
git checkout $CURRENT_BRANCH
git restore --staged "$1"
