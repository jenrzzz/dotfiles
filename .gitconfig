# vim: et sw=4 sts=4:
[alias]
    l  = log --pretty=onelinereltime --graph -n 20
    ll = log --pretty=onelinereltime --graph
    graphall = -c core.pager='less -SFRX' log --pretty=onelineall --graph --date-order

    # View the current working tree status using the short format
    s = status -s

    # Show the diff between the latest commit and the current state
    d = !"git diff-index --quiet HEAD -- || clear; git diff --patch-with-stat"

    # `git di $number` shows the diff between the state `$number` revisions ago and the current state
    di = !"d() { git diff --patch-with-stat HEAD~$1; }; git diff-index --quiet HEAD -- || clear; d"

    # Pull in remote changes for the current repository and all its submodules
    p = !"git pull; git submodule foreach git pull origin master"

    # Clone a repository including all submodules
    c = clone --recursive

    # Commit all changes
    ca = !git add -A && git commit -av

    # Switch to a branch, creating it if necessary
    go = checkout -B

    # Show verbose output about tags, branches or remotes
    tags = tag -l
    branches = branch -a
    remotes = remote -v

    # Undo a `git push`
    branch-name = "!git rev-parse --abbrev-ref HEAD"
    undopush = "!git push -f origin HEAD^:$(git branch-name)"

    ## Stuff from http://blog.apiaxle.com/post/handy-git-tips-to-stop-you-getting-fired/
    # Ignore local changes to a tracked file
    assumed  = "!git ls-files -v | grep ^h | cut -c 3-"
    assume   = update-index --assume-unchanged
    unassume = update-index --no-assume-unchanged

    # Take a snapshot of the current working tree
    snapshot = !git stash save "snapshot: $(date)" && git stash apply "stash@{0}"
    standup = "!git log --since yesterday --author $(git config user.email)"

    # Quickly resolve a merge, e.g. git theirs blah.rb
    ours   = "!f() { git checkout --ours $@ && git add $@; }; f"
    theirs = "!f() { git checkout --theirs $@ && git add $@; }; f"

[pretty]
    onelineall     = format:"%C(auto)%h %C(auto)%d %s %Cblue[%cn] %Cgreen[%cD]%Creset"
    onelinereltime = format:"%C(auto)%h%Creset %s %Cblue%cr%Creset"

[apply]
    # Detect whitespace errors when applying a patch
    whitespace = warn

[core]
    # Use custom `.gitignore` and `.gitattributes`
    excludesfile = ~/.gitignore
    attributesfile = ~/.gitattributes
    # Treat spaces before tabs, lines that are indented with 8 or more spaces, and all kinds of trailing whitespace as an error
    whitespace = space-before-tab,trailing-space
    autocrlf = input
	editor = /usr/bin/vim -u NONE -U NONE -N

[diff]
  algorithm = patience

[color]
    # Use colors in Git commands that are capable of colored output when outputting to the terminal
    ui = auto
[color "branch"]
    current = yellow reverse
    local = yellow
    remote = green
[color "diff"]
    meta = yellow bold
    frag = magenta bold
    old = red bold
    new = green bold
[color "status"]
    added = yellow
    changed = green
    untracked = cyan
[merge]
    # Include summaries of merged commits in newly created merge commit messages
    log = true
    conflictstyle = diff3
    tool = vimdiff

[push]
    default = simple

# Use `origin` as the default remote on the `master` branch in all cases
[branch "master"]
    merge = refs/heads/master
[remote "origin"]
    push = HEAD

# URL shorthands
[url "git@github.com:"]
    insteadOf = "gh:"
    pushInsteadOf = "github:"
    pushInsteadOf = "git://github.com/"
[url "git://github.com/"]
    insteadOf = "github:"
[url "git@gist.github.com:"]
    insteadOf = "gst:"
    pushInsteadOf = "gist:"
    pushInsteadOf = "git://gist.github.com/"
[url "git://gist.github.com/"]
    insteadOf = "gist:"
[user]
    name = Jenner La Fave
    # email = jenner@jfave.com
    email = jenner@flux.ai
    signingkey = 7E3BC2485101508C9BB45A1F345C047656B08155
    # signingkey = B5989E662182C4FA74E6A5ABF423CA2385368436
[pass]
    signcommits = true
[branch]
    autosetuprebase = always
[rerere]
    enabled = true
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
    required = true
	process = git-lfs filter-process
[gpg]
	program = gpg
[init]
	defaultBranch = main
[commit]
	gpgsign = true
