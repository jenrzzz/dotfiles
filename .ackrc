# Only search case-sensitive if input is mixed case
--smart-case

# New types
--type-set=puppet=.pp
--type-set=plaintext=.md,.mdown,.mkdn,.textile,.rst,.txt
--type-set=erb=.erb,.rhtml

--ignore-dir=is:log
--ignore-dir=is:app/cache
--ignore-dir=is:var/cache
--ignore-dir=is:public
--ignore-dir=is:node_modules
--ignore-dir=is:dist
--ignore-dir=is:tmp
--ignore-dir=is:.ropeproject
--ignore-dir=is:.virtualenv

# Ignore ctags
--ignore-file=is:tags
--ignore-file=is:build.js
