# Taskwarrior program configuration file.
# For more documentation, see http://taskwarrior.org or try 'man task', 'man task-faq',
# 'man task-tutorial', 'man task-color', 'man task-sync' or 'man taskrc'

# Here is an example of entries that use the default, override and blank values
#   variable=foo   -- By specifying a value, this overrides the default
#   variable=      -- By specifying no value, this means no default
#   #variable=foo  -- By commenting out the line, or deleting it, this uses the default

# Use the command 'task show' to see all defaults and overrides

# Files
data.location=~/.task
include solarized-dark-256.theme

pomodoro.taskwarrior_path=/opt/homebrew/bin/task
# uda.radar_id.type=string
# uda.radar_id.label=Radar
# context.nimbus=project:nimbus or project:infra or project:docapp
# context.allocations=project:allocations or project:infra or project:docapp
news.version=2.6.0
