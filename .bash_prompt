# @gf3’s Sexy Bash Prompt, inspired by “Extravagant Zsh Prompt”
# vim:ft=sh:
# Shamelessly copied from https://github.com/gf3/dotfiles
# Screenshot: http://i.imgur.com/s0Blh.png

if [[ $COLORTERM = gnome-* && $TERM = xterm ]] && infocmp gnome-256color >/dev/null 2>&1; then
	export TERM=gnome-256color
elif infocmp xterm-256color >/dev/null 2>&1; then
	export TERM=xterm-256color
fi

if [[ $TMUX ]]; then
    export TERM=screen-256color
fi

if tput setaf 1 &> /dev/null; then
	tput sgr0
	if [[ $(tput colors) -ge 256 ]] 2>/dev/null; then
		RED=$(tput setaf 124)
		MAGENTA=$(tput setaf 9)
		ORANGE=$(tput setaf 172)
		GREEN=$(tput setaf 190)
		PURPLE=$(tput setaf 141)
		WHITE=$(tput setaf 246)
  else
		RED=$(tput setaf 1)
		MAGENTA=$(tput setaf 5)
		ORANGE=$(tput setaf 4)
		GREEN=$(tput setaf 2)
		PURPLE=$(tput setaf 1)
		WHITE=$(tput setaf 7)
	fi
	BOLD=$(tput bold)
	RESET=$(tput sgr0)
else
	MAGENTA="\033[1;31m"
	ORANGE="\033[1;33m"
	GREEN="\033[1;32m"
	PURPLE="\033[1;35m"
	WHITE="\033[1;37m"
	BOLD=""
	RESET="\033[m"
fi

export RED
export MAGENTA
export ORANGE
export GREEN
export PURPLE
export WHITE
export BOLD
export RESET

function parse_git_in_rebase {
  [[ -d .git/rebase-apply ]] && echo -n " (rebasing)"
}

function parse_git_dirty() {
	# [[ $(git status 2> /dev/null | tail -n1) != *"working directory clean"* ]] && echo "*"
        git diff --exit-code &>/dev/null || echo -n "*"
        git diff --cached --exit-code &>/dev/null || echo -n "^"
}

function parse_git_branch() {
	git branch --no-color 2> /dev/null | sed -e '/^[^*]/d' -e "s/* \(.*\)/\1$(parse_git_dirty)$(parse_git_in_rebase)/"
}

function rbenv_ruby_version {
  local v=$(rbenv version | awk '{ print $1 }' | sed -e 's/\.[^.]$//')
  [[ $v = 'system' ]] && [[ ! -z "$PS1_RBENV_VERSION" ]] && echo " ($v) "
}

export PS1_DEFAULT="\[${BOLD}${MAGENTA}\]\u\[$WHITE\]@\[$ORANGE\]\h\[$WHITE\]:\[$GREEN\]\w\[$WHITE\]\$([[ -n \$(git branch 2> /dev/null) ]] && echo \" on \")\[$PURPLE\]\$(parse_git_branch)\[$RED\]\$(rbenv_ruby_version)\[$WHITE\]\$ \[$RESET\]"
export PS1_CDBLK="\[${BOLD}${MAGENTA}\]\u\[$WHITE\]@\[$ORANGE\]\h\[$WHITE\]:\[$GREEN\]\w\[$WHITE\]\$([[ -n \$(git branch 2> /dev/null) ]] && echo \" on \")\[$PURPLE\]\$(parse_git_branch)\[$WHITE\]\$(rbenv_ruby_version) [cdblk] \$ \[$RESET\]"
export PS1_SCRATCH="\[${BOLD}${MAGENTA}\]\u\[$WHITE\]@\[$ORANGE\]\h\[$WHITE\]:\[$GREEN\]\w\[$WHITE\]\$([[ -n \$(git branch 2> /dev/null) ]] && echo \" on \")\[$PURPLE\]\$(parse_git_branch)\[$WHITE\]\$(rbenv_ruby_version) [scratch] \$ \[$RESET\]"
export PS1="$PS1_DEFAULT"

export HISTTIMEFORMAT="%s "
[[ ! $PROMPT_COMMAND =~ .bash_eternal_history ]] && PROMPT_COMMAND="${PROMPT_COMMAND:+$PROMPT_COMMAND }"'echo "$$ $USER \"$(history 1)\"" >> ~/.bash_eternal_history;export PREV_COMMAND=""'

function settitle () {
    export PREV_COMMAND=${PREV_COMMAND}${@}
    echo -ne "\033k${PREV_COMMAND/%\ */}\033\\"
    export PREV_COMMAND=${PREV_COMMAND}' | '
}

# trap 'settitle "$BASH_COMMAND"' DEBUG
