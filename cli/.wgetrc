# Use the server-provided last modification date, if available
timestamping = on

# Don't ascend to the parent directory when downloading recursively
no_parent = on

# Time out after 60s on all phases (DNS, connect, read; default read is 15 min!)
timeout = 60

# Retry a few times, including on connection refused (default tries is 20)
tries = 3
retry_connrefused = on

# Follow FTP links from HTML documents
follow_ftp = on

# Add a sensible extension to html/css files that lack one
adjust_extension = on

# Ignore robots.txt / nofollow
robots = off

# Print the HTTP/FTP server responses
server_response = on

# (Dropped the fake "IE9 on Windows 7" user-agent — set --user-agent per-call if needed.)
