#!/usr/bin/env bash
#
# tmux-move-window — move the current window into another (or a brand-new) session.
# Meant to run inside `display-popup -E` (see .tmux.conf binding `C-a M`).

set -uo pipefail

here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
. "$here/lib/tmux-session-lib.sh"

cur_session="$(tmux display-message -p '#S')"
cur_win="$(tmux display-message -p '#{window_id}')"
cur_dir="$(tmux display-message -p '#{pane_current_path}')"

NEW_ENTRY="＋ new session…"

# Offer every session except the one we're in, plus the "new" entry.
selection="$(
	{
		tmux list-sessions -F '#{session_name}' | grep -vxF "$cur_session"
		printf '%s\n' "$NEW_ENTRY"
	} | fzf --height=100% --reverse --prompt='move window to> ' \
	        --header="moving: $(tmux display-message -p '#W')"
)"

[[ -n "$selection" ]] || exit 0

if [[ "$selection" == "$NEW_ENTRY" ]]; then
	read -r -p 'new session name: ' raw
	[[ -n "$raw" ]] || exit 0
	target="$(sanitize_session_name "$raw")"
else
	target="$selection"
fi

move_window_to_session "$cur_win" "$target" "$cur_dir"
tmux switch-client -t "=$target"
